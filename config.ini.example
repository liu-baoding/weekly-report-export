; ============================================================
; 周报平台块导出工具 - 配置文件模板
; 使用前请复制为 config.ini 并填写真实值
; ============================================================

[config]
; JWT 认证令牌
; 获取方式：浏览器 F12 → 网络 → 找到任意请求 → 复制 Authorization: Bearer 后面的值
; 注意：令牌会过期，过期后需要重新获取
TOKEN = YOUR_JWT_TOKEN_HERE

; 目标容器块的块链接
; 获取方式：点击目标块右上角的控制符 → 复制块链接
; 容器块 ID 自动从链接中 # 后面的部分提取
BLOCK_LINK = https://note.kxsz.net/w/YOUR_PAGE_ID#YOUR_BLOCK_ID

; 团队空间名称（用于自动匹配 space_id，一般不需要改）
SPACE_NAME = ATE Lab Co-work
